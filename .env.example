# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# TU REST API
TU_API_URL=https://restapi.tu.ac.th/api/v1/auth/Ad/verify
TU_APP_KEY=your-tu-app-key-here
MOCK_API=True

# HTTPS/security defaults for deployment
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Email Settings (Gmail)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here

# AI Booking
AI_API_KEY=your-ai-api-key-here
AI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
AI_MODEL="gemini-2.5-flash-lite"

# Database (For Docker)
DATABASE_NAME=roombooking
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=db
DATABASE_PORT=5432
